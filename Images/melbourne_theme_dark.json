{
  "name": "Melbourne Housing — Dark",
  "dataColors": [
    "#3B9EFF",
    "#F5A623",
    "#2DD4A7",
    "#A78BFA",
    "#22D3EE",
    "#FB7185",
    "#94A3B8",
    "#FBBF24"
  ],
  "foreground": "#E8EDF5",
  "foregroundNeutralSecondary": "#9FB0C7",
  "foregroundNeutralTertiary": "#6B7C93",
  "background": "#131A2A",
  "backgroundLight": "#1A2337",
  "backgroundNeutral": "#1E2739",
  "tableAccent": "#3B9EFF",
  "good": "#2DD4A7",
  "neutral": "#F5A623",
  "bad": "#FB7185",
  "maximum": "#3B9EFF",
  "center": "#1E5A8F",
  "minimum": "#16233A",

  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI Semibold",
      "color": "#FFFFFF"
    },
    "title": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#E8EDF5"
    },
    "header": {
      "fontSize": 11,
      "fontFace": "Segoe UI Semibold",
      "color": "#E8EDF5"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#9FB0C7"
    }
  },

  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#131A2A" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#25314A" } },
            "radius": 6
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#E8EDF5" } },
            "background": { "solid": { "color": "#1A2337" } },
            "alignment": "center",
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "subTitle": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#6B7C93" } },
            "alignment": "left",
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "visualHeader": [
          {
            "show": true,
            "background": { "solid": { "color": "#131A2A" } },
            "foreground": { "solid": { "color": "#6B7C93" } },
            "transparency": 100
          }
        ],
        "labels": [
          {
            "show": true,
            "color": { "solid": { "color": "#E8EDF5" } },
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ],
        "categoryAxis": [
          {
            "show": true,
            "showAxisTitle": false,
            "labelColor": { "solid": { "color": "#9FB0C7" } },
            "fontSize": 9,
            "fontFamily": "Segoe UI",
            "gridlineShow": false
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "showAxisTitle": false,
            "labelColor": { "solid": { "color": "#9FB0C7" } },
            "fontSize": 9,
            "fontFamily": "Segoe UI",
            "gridlineShow": true,
            "gridlineColor": { "solid": { "color": "#25314A" } },
            "gridlineThickness": 1,
            "gridlineStyle": "solid"
          }
        ],
        "legend": [
          {
            "show": true,
            "position": "Top",
            "showTitle": false,
            "labelColor": { "solid": { "color": "#9FB0C7" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },

    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#0B1220" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#0B1220" } },
            "transparency": 0
          }
        ]
      }
    },

    "card": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#0B1220" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#FFFFFF" } },
            "fontSize": 26,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#3B9EFF" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },

    "slicer": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#1A2337" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#25314A" } },
            "radius": 4
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#9FB0C7" } },
            "background": { "solid": { "color": "#1A2337" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#E8EDF5" } },
            "background": { "solid": { "color": "#1A2337" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },

    "lineChart": {
      "*": {
        "lineStyles": [
          {
            "strokeWidth": 2,
            "lineStyle": "solid",
            "showMarker": true,
            "markerSize": 4
          }
        ]
      }
    },

    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#25314A" } },
            "outlineColor": { "solid": { "color": "#25314A" } },
            "rowPadding": 4
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#E8EDF5" } },
            "backColor": { "solid": { "color": "#1A2337" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#9FB0C7" } },
            "backColor": { "solid": { "color": "#131A2A" } },
            "backColorSecondary": { "solid": { "color": "#131A2A" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    }
  }
}
