{
  "name": "Melbourne Housing — Violet",
  "dataColors": [
    "#4338CA",
    "#6366F1",
    "#8B85F0",
    "#06B6D4",
    "#A5A0F5",
    "#22D3EE",
    "#C7C4FA",
    "#67E8F9"
  ],
  "foreground": "#1E1B4B",
  "foregroundNeutralSecondary": "#5B5788",
  "foregroundNeutralTertiary": "#9490B8",
  "background": "#FFFFFF",
  "backgroundLight": "#F7F6FE",
  "backgroundNeutral": "#E8E6FA",
  "tableAccent": "#4338CA",
  "good": "#06B6D4",
  "neutral": "#8B85F0",
  "bad": "#E24B4A",
  "maximum": "#312BA0",
  "center": "#8B85F0",
  "minimum": "#EDECFD",

  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI Semibold",
      "color": "#1E1B4B"
    },
    "title": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#1E1B4B"
    },
    "header": {
      "fontSize": 11,
      "fontFace": "Segoe UI Semibold",
      "color": "#1E1B4B"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#5B5788"
    }
  },

  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#D8D5F5" } },
            "radius": 6
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#1E1B4B" } },
            "background": { "solid": { "color": "#FFFFFF" } },
            "alignment": "left",
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "subTitle": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#9490B8" } },
            "alignment": "left",
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "visualHeader": [
          {
            "show": true,
            "background": { "solid": { "color": "#FFFFFF" } },
            "foreground": { "solid": { "color": "#9490B8" } },
            "transparency": 100
          }
        ],
        "labels": [
          {
            "show": true,
            "color": { "solid": { "color": "#1E1B4B" } },
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ],
        "categoryAxis": [
          {
            "show": true,
            "showAxisTitle": false,
            "labelColor": { "solid": { "color": "#5B5788" } },
            "fontSize": 9,
            "fontFamily": "Segoe UI",
            "gridlineShow": false
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "showAxisTitle": false,
            "labelColor": { "solid": { "color": "#5B5788" } },
            "fontSize": 9,
            "fontFamily": "Segoe UI",
            "gridlineShow": true,
            "gridlineColor": { "solid": { "color": "#EDECFD" } },
            "gridlineThickness": 1,
            "gridlineStyle": "solid"
          }
        ],
        "legend": [
          {
            "show": true,
            "position": "TopLeft",
            "showTitle": false,
            "labelColor": { "solid": { "color": "#5B5788" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },

    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#FAFAFE" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#FAFAFE" } },
            "transparency": 0
          }
        ]
      }
    },

    "card": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#D8D5F5" } },
            "radius": 6
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#1E1B4B" } },
            "fontSize": 26,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#6366F1" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },

    "slicer": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#D8D5F5" } },
            "radius": 6
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#5B5788" } },
            "background": { "solid": { "color": "#FFFFFF" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#1E1B4B" } },
            "background": { "solid": { "color": "#FFFFFF" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },

    "lineChart": {
      "*": {
        "lineStyles": [
          {
            "strokeWidth": 2,
            "lineStyle": "solid",
            "showMarker": false
          }
        ]
      }
    },

    "donutChart": {
      "*": {
        "slices": [
          {
            "innerRadiusRatio": 60
          }
        ]
      }
    },

    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#EDECFD" } },
            "outlineColor": { "solid": { "color": "#D8D5F5" } },
            "rowPadding": 4
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#4338CA" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#1E1B4B" } },
            "backColor": { "solid": { "color": "#FFFFFF" } },
            "backColorSecondary": { "solid": { "color": "#FAFAFE" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    }
  }
}
